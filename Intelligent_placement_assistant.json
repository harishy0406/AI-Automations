    {
      "parameters": {
        "jsCode": "const MY_ID = \"K2Q0M802\".toLowerCase().trim();\n\nlet selected = false;\n\nfor (const item of $input.all()) {\n\n  const values = Object.values(item.json).map(v =>\n    String(v).toLowerCase().trim()\n  );\n\n  if (values.includes(MY_ID)) {\n    selected = true;\n    break;\n  }\n}\n\nreturn [\n  {\n    json: {\n      selected\n    }\n  }\n];"
